# PlaceIQ Environment Variables
# Copy this file to .env and fill in your values

# ─── Required for AI features ───────────────────────────────────────────────
# Get your Gemini API key from https://aistudio.google.com/
GEMINI_API_KEY=your_key
# ─── Django settings ─────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=placeiq-change-this-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Database (default: SQLite, no config needed) ────────────────────────────
# For PostgreSQL, uncomment and fill in:
# DATABASE_URL=postgresql://user:password@localhost:5432/placeiq

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=8000
